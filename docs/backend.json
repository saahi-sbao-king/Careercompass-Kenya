{
  "entities": {
    "User": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "User",
      "type": "object",
      "description": "Represents a student profile with authentication and assessment data.",
      "properties": {
        "id": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "username": { "type": "string" },
        "role": { "type": "string", "enum": ["student", "teacher"] },
        "photoURL": { "type": "string" },
        "hashedPassword": { "type": "string" },
        "assessment": {
          "type": "object",
          "description": "Results of the Multiple Intelligence evaluation."
        },
        "createdAt": { "type": "string", "format": "date-time" },
        "lastActive": { "type": "string", "format": "date-time" }
      }
    },
    "StudyLog": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "StudyLog",
      "type": "object",
      "properties": {
        "subject": { "type": "string" },
        "duration": { "type": "number" },
        "date": { "type": "string" },
        "guestId": { "type": "string" }
      }
    }
  },
  "auth": {
    "providers": ["google", "credentials"],
    "reasoning": "Auth.js v5 providing Google and Email/Password access for students of Frere Town Secondary."
  },
  "firestore": {
    "structure": [
      {
        "path": "/users/{userId}",
        "definition": {
          "entityName": "User",
          "schema": { "$ref": "#/backend/entities/User" },
          "description": "Core student profile and career data."
        }
      },
      {
        "path": "/users/{userId}/studyLogs/{logId}",
        "definition": {
          "entityName": "StudyLog",
          "schema": { "$ref": "#/backend/entities/StudyLog" },
          "description": "Daily academic effort logs."
        }
      }
    ],
    "reasoning": "Fully permissive rules applied to support public service model and legacy guest continuity."
  }
}