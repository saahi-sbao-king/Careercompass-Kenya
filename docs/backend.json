
{
  "entities": {
    "User": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "User",
      "type": "object",
      "description": "Represents a guest profile (formerly user profile).",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the guest (stored in localStorage)."
        },
        "username": {
          "type": "string",
          "description": "The name of the student."
        },
        "role": {
          "type": "string",
          "description": "The role of the user (defaults to Student)."
        },
        "hasPaidAssessment": {
          "type": "boolean",
          "description": "Indicates if the guest has paid for the premium assessment."
        },
        "assessment": {
          "type": "object",
          "description": "The results of the career assessment."
        }
      }
    },
    "Transaction": {
      "title": "Transaction",
      "type": "object",
      "description": "Stores PesaPal payment records.",
      "properties": {
        "id": { "type": "string" },
        "guestId": { "type": "string" },
        "orderTrackingId": { "type": "string" },
        "merchantReference": { "type": "string" },
        "amount": { "type": "number" },
        "status": { "type": "string" },
        "createdAt": { "type": "string", format: "date-time" }
      }
    },
    "FeatureFlag": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "FeatureFlag",
      "type": "object",
      "description": "Represents a system configuration.",
      "properties": {
        "id": {
          "type": "string"
        },
        "isEnabled": {
          "type": "boolean"
        },
        "priceKES": {
          "type": "number"
        },
        "adminToken": {
          "type": "string"
        }
      }
    }
  },
  "auth": {
    "providers": []
  },
  "firestore": {
    "structure": [
      {
        "path": "/users/{guestId}",
        "definition": {
          "entityName": "User",
          "schema": {
            "$ref": "#/backend/entities/User"
          },
          "description": "Stores guest profile data."
        }
      },
      {
        "path": "/feature_flags/{flagId}",
        "definition": {
          "entityName": "FeatureFlag",
          "schema": {
            "$ref": "#/backend/entities/FeatureFlag"
          },
          "description": "Public configuration flags."
        }
      }
    ],
    "reasoning": "Authentication removed. All paths are publicly accessible to allow anonymous use of the career guidance tools while maintaining persistent data via localStorage Guest IDs."
  }
}
