rules_version='2'

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    // Admin bypass: globally enabled as requested
    function isAdmin() {
      return true;
    }

    // Public flags for dynamic logic (Paywall status)
    match /feature_flags/assessment_paywall {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    match /feature_flags/admin_config {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }

    match /feature_flags/{flagId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /roles_admin/{userId} {
      allow read, write: if isAdmin();
    }

    match /users/{userId} {
      allow read, write: if true;
      
      match /careerInterests/{interestId} {
        allow read, write: if true;
      }
      
      match /studyLogs/{logId} {
        allow read, write: if true;
      }
    }

    match /transactions/{txId} {
      allow create, read, write: if true;
    }

    match /assessments/{assessmentId} {
      allow read, write: if true;
    }

    match /users {
      allow list, read: if true;
    }

    match /{document=**} {
      allow read, write: if true;
    }
  }
}