rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    /**
     * SIDMADINA STRATEGIC SECURITY MODEL (v5.0.0)
     * Optimized for CareerCompass Kenya CBE System.
     */
    
    // Function to check if the requester is the owner of the document
    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    // Function to check if the user is an admin
    function isAdmin() {
      return request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Public Collections: Accessible to all authenticated users and guests for reading
    match /subjects/{id} { allow read: if true; allow write: if isAdmin(); }
    match /pathways/{id} { allow read: if true; allow write: if isAdmin(); }
    match /career_clusters/{id} { allow read: if true; allow write: if isAdmin(); }
    match /careers/{id} { allow read: if true; allow write: if isAdmin(); }
    match /universities/{id} { allow read: if true; allow write: if isAdmin(); }
    match /tvets/{id} { allow read: if true; allow write: if isAdmin(); }
    match /courses/{id} { allow read: if true; allow write: if isAdmin(); }
    match /scholarships/{id} { allow read: if true; allow write: if isAdmin(); }
    match /market_demand/{id} { allow read: if true; allow write: if isAdmin(); }
    match /roadmaps/{id} { allow read: if true; allow write: if isAdmin(); }

    // User Data: Strictly protected for privacy
    match /users/{userId} {
      allow read, write: if isOwner(userId) || isAdmin();
      
      // Sub-collections like study logs inherit or have specific rules
      match /{allSubcollections=**} {
        allow read, write: if isOwner(userId) || isAdmin();
      }
    }

    // Career Predictions: Users can only see their own predictions
    match /career_predictions/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow write: if isAdmin(); // Only system/admins generate these
    }

    // Assessments: General structure is readable, responses are per-user
    match /assessments/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}