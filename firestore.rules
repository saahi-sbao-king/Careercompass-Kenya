rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    /**
     * GLOBAL ADMINISTRATIVE ACCESS (Production Patch v1.0.2)
     * This system is configured to allow public access to core configurations
     * and administrative management without mandatory authentication.
     */
    
    // Explicitly allow public read access to system configuration/feature flags
    match /feature_flags/{flagId} {
      allow read: if true;
      allow write: if true; // Admin management enabled
    }

    // Global match for all other collections
    match /{document=**} {
      allow read, write: if true;
    }
  }
}