rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    /**
     * GLOBAL ADMINISTRATIVE ACCESS
     * As requested, the system is now fully permissive to allow management
     * without authentication requirements. This applies to all collections.
     */
    match /{document=**} {
      allow read, write: if true;
    }
    
    // Explicit rule for feature flags to ensure system logic (like paywalls) 
    // can always be checked regardless of auth state.
    match /feature_flags/{flagId} {
      allow read, write: if true;
    }
  }
}