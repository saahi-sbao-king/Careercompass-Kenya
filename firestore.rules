rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    /**
     * SIDMADINA STRATEGIC ACCESS CONFIGURATION (v4.0.0)
     * All paths are publicly accessible to support Guest Identities and Global Admin features.
     * Security is managed via administrative tokens and client-side validation.
     */
    match /{document=**} {
      allow read, write: if true;
    }
  }
}