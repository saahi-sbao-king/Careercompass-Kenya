rules_version='2'

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }

    // Public flags for initial load
    match /feature_flags/assessment_paywall {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    match /feature_flags/admin_config {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }

    match /feature_flags/{flagId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /roles_admin/{userId} {
      allow read: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow write: if isAdmin();
    }

    match /users/{userId} {
      allow read: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow write: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      
      match /careerInterests/{interestId} {
        allow read, write: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      }
      
      match /studyLogs/{logId} {
        allow read, write: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      }
    }

    match /transactions/{txId} {
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow list: if isAdmin();
    }

    match /assessments/{assessmentId} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow write: if isSignedIn() && (request.resource.data.userId == request.auth.uid || isAdmin());
    }

    match /users {
      allow list: if isAdmin();
    }

    match /{document=**} {
      allow read, write: if isAdmin();
    }
  }
}
